{
    "name": "@arovave/server",
    "version": "0.1.0",
    "private": true,
    "description": "Fastify backend for pricing engine",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/app.ts",
        "build": "tsc",
        "start": "node dist/app.js",
        "test": "vitest run",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:migrate": "prisma migrate dev",
        "db:seed": "tsx prisma/seed.ts"
    },
    "dependencies": {
        "@arovave/engine": "*",
        "@fastify/cors": "^10.0.0",
        "@fastify/sensible": "^6.0.0",
        "@prisma/client": "^6.0.0",
        "decimal.js": "^10.4.3",
        "dotenv": "^16.4.0",
        "fastify": "^5.0.0",
        "jspdf": "4.2.1",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "prisma": "^6.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.5.0",
        "vitest": "^4.1.2"
    }
}
