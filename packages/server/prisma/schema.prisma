// Prisma Schema for Dynamic Pricing Engine
// All financial values stored as Decimal(18,4)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Product ─────────────────────────────────────────────────────────

model Product {
  id               String          @id @default(uuid()) @db.Uuid
  name             String
  slug             String          @unique
  status           ProductStatus   @default(DRAFT)
  currentVersionId String?         @map("current_version_id") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  versions         ProductVersion[]

  @@map("products")
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─── Product Version (Immutable once published) ──────────────────────

model ProductVersion {
  id            String   @id @default(uuid()) @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  versionNumber Int      @map("version_number")
  schemaJson    Json     @map("schema_json")
  isActive      Boolean  @default(false) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sections      Section[]
  formulas      Formula[]
  quotes        Quote[]

  @@unique([productId, versionNumber])
  @@map("product_versions")
}

// ─── Section ─────────────────────────────────────────────────────────

model Section {
  id         String         @id @default(uuid()) @db.Uuid
  versionId  String         @map("version_id") @db.Uuid
  name       String
  orderIndex Int            @map("order_index")

  version    ProductVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  fields     Field[]

  @@map("sections")
}

// ─── Field ───────────────────────────────────────────────────────────

model Field {
  id           String      @id @default(uuid()) @db.Uuid
  sectionId    String      @map("section_id") @db.Uuid
  type         FieldType
  key          String
  label        String
  isRequired   Boolean     @default(false) @map("is_required")
  isVisible    Boolean     @default(true) @map("is_visible")
  defaultValue String?     @map("default_value")
  metadataJson Json?       @map("metadata_json")

  section      Section     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  options      FieldOption[]

  @@map("fields")
}

enum FieldType {
  NUMBER
  DROPDOWN
  FIXED
  FORMULA
  CONDITIONAL
  OUTPUT
}

// ─── Field Option (for dropdowns) ────────────────────────────────────

model FieldOption {
  id           String  @id @default(uuid()) @db.Uuid
  fieldId      String  @map("field_id") @db.Uuid
  label        String
  value        String
  rate         Decimal @db.Decimal(18, 4)
  metadataJson Json?   @map("metadata_json")

  field        Field   @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@map("field_options")
}

// ─── Formula ─────────────────────────────────────────────────────────

model Formula {
  id            String         @id @default(uuid()) @db.Uuid
  versionId     String         @map("version_id") @db.Uuid
  outputKey     String         @map("output_key")
  operationType String         @map("operation_type")
  operandsJson  Json           @map("operands_json")
  orderIndex    Int            @map("order_index")

  version       ProductVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@map("formulas")
}

// ─── Quote (Immutable) ───────────────────────────────────────────────

model Quote {
  id                  String         @id @default(uuid()) @db.Uuid
  productVersionId    String         @map("product_version_id") @db.Uuid
  inputSnapshotJson   Json           @map("input_snapshot_json")
  outputSnapshotJson  Json           @map("output_snapshot_json")
  inputHash           String         @map("input_hash")
  totalAmountDecimal  Decimal        @map("total_amount_decimal") @db.Decimal(18, 4)
  createdAt           DateTime       @default(now()) @map("created_at")

  productVersion      ProductVersion @relation(fields: [productVersionId], references: [id])

  @@map("quotes")
}
